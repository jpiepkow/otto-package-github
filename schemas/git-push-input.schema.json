{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.git_push_input",
  "title": "Push Git Ref Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repo",
    "refspec"
  ],
  "properties": {
    "repo": {
      "$ref": "grant-scope.schema.json#/$defs/repository"
    },
    "refspec": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "force": {
      "type": "boolean",
      "default": false
    },
    "remote": {
      "type": "string",
      "default": "origin",
      "minLength": 1,
      "maxLength": 255
    }
  }
}
