{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.write_output",
  "title": "GitHub Write Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "output"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "output": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
