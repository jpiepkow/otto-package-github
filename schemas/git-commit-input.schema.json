{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.git_commit_input",
  "title": "Commit Git Changes Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repo",
    "message"
  ],
  "properties": {
    "repo": {
      "$ref": "grant-scope.schema.json#/$defs/repository"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 10000
    }
  }
}
