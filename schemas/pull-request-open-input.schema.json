{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.pull_request_open_input",
  "title": "Open Pull Request Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repo",
    "title",
    "head",
    "base"
  ],
  "properties": {
    "repo": {
      "$ref": "#/$defs/repository"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "head": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "base": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "body": {
      "type": "string",
      "maxLength": 65536
    }
  },
  "$defs": {
    "repository": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    }
  }
}
