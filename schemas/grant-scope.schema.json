{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.grant_scope",
  "title": "GitHub Grant Scope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "unrestricted": {
            "const": true
          }
        },
        "required": [
          "unrestricted"
        ]
      },
      "then": {},
      "else": {
        "required": [
          "allowed_repos",
          "allowed_refs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "auth_mode": {
            "const": "token"
          }
        },
        "required": [
          "auth_mode"
        ]
      },
      "then": {
        "required": [
          "credential_ref"
        ]
      }
    }
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": [
        "read",
        "write"
      ]
    },
    "auth_mode": {
      "type": "string",
      "enum": [
        "host",
        "token"
      ],
      "default": "host"
    },
    "unrestricted": {
      "type": "boolean",
      "default": false
    },
    "credential_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "allowed_repos": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/repository"
      }
    },
    "allowed_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      }
    },
    "max_file_lines": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000,
      "default": 120
    },
    "max_file_bytes": {
      "type": "integer",
      "minimum": 1024,
      "maximum": 262144,
      "default": 32768
    },
    "max_matches": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 20
    },
    "max_results": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 30
    },
    "context_lines": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20,
      "default": 3
    },
    "max_clone_bytes": {
      "type": "integer",
      "minimum": 1048576,
      "maximum": 5368709120,
      "default": 524288000
    }
  },
  "$defs": {
    "repository": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    }
  }
}
