{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.branch_delete_input",
  "title": "Delete GitHub Branch Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repo",
    "branch"
  ],
  "properties": {
    "repo": {
      "$ref": "#/$defs/repository"
    },
    "branch": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    }
  },
  "$defs": {
    "repository": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    }
  }
}
