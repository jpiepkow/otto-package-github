{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.git_stage_input",
  "title": "Stage Git Changes Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repo"
  ],
  "properties": {
    "repo": {
      "$ref": "#/$defs/repository"
    },
    "paths": {
      "type": "array",
      "default": [
        "."
      ],
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 4096
      }
    }
  },
  "$defs": {
    "repository": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    }
  }
}
