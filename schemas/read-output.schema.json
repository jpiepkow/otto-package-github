{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.read_output",
  "title": "Bounded GitHub Read Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "output"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lines",
        "truncated",
        "total_lines"
      ],
      "properties": {
        "lines": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 2000
          }
        },
        "truncated": {
          "type": "boolean"
        },
        "total_lines": {
          "type": "integer",
          "minimum": 0
        },
        "match_count": {
          "type": "integer",
          "minimum": 0
        },
        "remainder": {
          "type": "integer",
          "minimum": 0
        },
        "repo": {
          "$ref": "#/$defs/repository"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "state": {
          "type": "string",
          "enum": [
            "open",
            "closed",
            "all"
          ]
        }
      }
    }
  },
  "$defs": {
    "repository": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    }
  }
}
