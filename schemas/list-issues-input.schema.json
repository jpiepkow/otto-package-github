{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.list_issues_input",
  "title": "List GitHub Issues Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repo"
  ],
  "properties": {
    "repo": {
      "$ref": "grant-scope.schema.json#/$defs/repository"
    },
    "state": {
      "type": "string",
      "enum": [
        "open",
        "closed",
        "all"
      ],
      "default": "open"
    },
    "max_results": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    }
  }
}
