{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.comment_input",
  "title": "GitHub Comment Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repo",
    "issue_or_pr_number",
    "body"
  ],
  "properties": {
    "repo": {
      "$ref": "#/$defs/repository"
    },
    "issue_or_pr_number": {
      "type": "integer",
      "minimum": 1
    },
    "body": {
      "type": "string",
      "minLength": 1,
      "maxLength": 65536
    }
  },
  "$defs": {
    "repository": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    }
  }
}
