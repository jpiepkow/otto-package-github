{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.search_code_input",
  "title": "Search GitHub Code Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "query"
  ],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "repo": {
      "$ref": "grant-scope.schema.json#/$defs/repository"
    }
  }
}
