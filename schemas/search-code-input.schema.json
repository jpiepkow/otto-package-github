{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.search_code_input",
  "title": "Search GitHub Code Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "query"
  ],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "repo": {
      "$ref": "#/$defs/repository"
    }
  },
  "$defs": {
    "repository": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    }
  }
}
