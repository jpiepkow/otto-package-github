{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.list_commits_input",
  "title": "List GitHub Commits Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repo"
  ],
  "properties": {
    "repo": {
      "$ref": "grant-scope.schema.json#/$defs/repository"
    },
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "default": "HEAD"
    },
    "max_results": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    }
  }
}
