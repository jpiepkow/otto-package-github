{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.github.prepare_checkout_output",
  "title": "Prepare GitHub Checkout Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "output"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host_path",
        "mount_path",
        "owner",
        "repo",
        "ref",
        "commit_sha",
        "file_count",
        "size_bytes",
        "truncated"
      ],
      "properties": {
        "host_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "mount_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "owner": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "repo": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "commit_sha": {
          "type": "string",
          "minLength": 7,
          "maxLength": 64
        },
        "file_count": {
          "type": "integer",
          "minimum": 0
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        }
      }
    }
  }
}
